# Ejemplo de configuración de variables de entorno
# Copia este archivo a .env y actualiza los valores

# Puerto del servidor
PORT=3000

# Seguridad - CAMBIAR EN PRODUCCIÓN
SESSION_SECRET=cambiar-esta-clave-secreta-en-produccion

# Credenciales de administrador - CAMBIAR EN PRODUCCIÓN
ADMIN_EMAIL=admin@admin.com
ADMIN_PASSWORD=admin123

# Base de datos MongoDB (opcional)
# Si no se configura, el chat no se persistirá en base de datos
# Ejemplos:
# - Local: mongodb://localhost:27017/sharecode
# - MongoDB Atlas: mongodb+srv://usuario:password@cluster.mongodb.net/sharecode
MONGO_URI=

# Limpieza automática
CLEANUP_INTERVAL_DAYS=1
WORKSPACE_EXPIRY_DAYS=30
